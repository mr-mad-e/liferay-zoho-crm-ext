# ─────────────────────────────────────────────
#  Liferay ↔ Zoho CRM Client Extension — .env
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Liferay DXP
LIFERAY_BASE_URL=http://localhost:8080
LIFERAY_CLIENT_ID=your-liferay-client-id
LIFERAY_CLIENT_SECRET=your-liferay-client-secret

# Zoho CRM OAuth 2.0
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=http://localhost:3000/auth/zoho/callback
ZOHO_REFRESH_TOKEN=your-initial-refresh-token
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_BASE_URL=https://www.zohoapis.com/crm/v3
ZOHO_SCOPE=ZohoCRM.modules.ALL,ZohoCRM.settings.ALL

# Redis Cache (optional)
REDIS_URL=redis://localhost:6379
REDIS_TOKEN_TTL=3500
REDIS_CACHE_TTL=300

# Webhook Security
WEBHOOK_SECRET=your-webhook-hmac-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# API Key for Liferay → Extension auth
INTERNAL_API_KEY=your-secure-internal-api-key
